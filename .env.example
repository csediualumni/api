# Database — use the Public URL from Railway dashboard (db service → Variables → DATABASE_PUBLIC_URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/railway

# Redis — use the Public URL from Railway dashboard (Redis service → Variables → REDIS_PUBLIC_URL)
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# S3-compatible storage (Tigris / T3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=https://t3.storageapi.dev
AWS_S3_BUCKET_NAME=
AWS_DEFAULT_REGION=auto

# SMTP — for password recovery emails
# Gmail example: use an App Password (not your account password)
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=support@csediualumni.com

# Frontend URL (used in reset-password email links)
FRONTEND_URL=http://localhost:4200
